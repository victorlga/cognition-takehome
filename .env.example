# Devin API — create a service user at https://app.devin.ai (Team Settings > Service Users)
DEVIN_API_KEY=
DEVIN_ORG_ID=

# GitHub — personal access token with `repo` scope
GITHUB_TOKEN=

# Optional: polling interval in seconds (default: 30)
# POLL_INTERVAL_SECONDS=30

# Optional: disable background polling (default: true)
# POLLING_ENABLED=true
